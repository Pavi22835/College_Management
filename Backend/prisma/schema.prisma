generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  Int       @id @default(autoincrement())
  email               String    @unique
  password            String
  name                String
  role                Role      @default(STUDENT)
  isActive            Boolean   @default(true)
  status              String    @default("active")      // active, inactive, deactivated, suspended
  deactivatedAt       DateTime?
  deactivatedReason   String?
  deactivatedBy       Int?
  activatedAt         DateTime?
  lastLogin           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  admin               Admin?
  student             Student?
  staff               Staff?
}

model Student {
  id                 Int          @id @default(autoincrement())
  userId             Int          @unique
  rollNo             String       @unique
  email              String       @unique
  name               String
  age                Int?
  gender             String?
  course             String?
  semester           Int?
  batch              String?
  phone              String?
  address            String?
  dateOfBirth        DateTime?
  guardianPhone      String?
  deletedAt          DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  admissionType      String?
  admissionYear      String?
  enrollmentNo       String?      @unique
  fatherName         String?
  motherName         String?
  previousCollege    String?
  previousPercentage Float?
  section            String?
  teacherId          Int?
  attendances        Attendance[]
  enrollments        Enrollment[]
  assignmentSubmissions AssignmentSubmission[]
  teacher            Staff?       @relation("TeacherStudents", fields: [teacherId], references: [id])
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([rollNo])
  @@index([teacherId])
  @@index([course])
  @@index([batch])
  @@index([deletedAt])
}

model Staff {
  id               Int          @id @default(autoincrement())
  userId           Int          @unique
  employeeId       String       @unique
  department       String
  designation      String
  phone            String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  deletedAt        DateTime?
  email            String       @unique
  name             String
  courses          Course[]
  teacherStudents  Student[]    @relation("TeacherStudents")
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([department])
  @@index([deletedAt])
  @@index([employeeId])
}

model Admin {
  id         Int      @id @default(autoincrement())
  userId     Int      @unique
  employeeId String   @unique
  department String?
  phone      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  email      String   @unique
  name       String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Department {
  id               Int       @id @default(autoincrement())
  code             String    @unique
  name             String    @unique
  hodId            Int?      @unique
  hodAppointedDate DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?
  deletedBy        Int?

  @@index([code])
  @@index([hodId])
  @@index([deletedAt])
}

model Course {
  id          Int          @id @default(autoincrement())
  code        String       @unique
  name        String
  description String?
  credits     Int?
  department  String
  semester    Int?
  teacherId   Int?
  status      String       @default("ACTIVE")
  schedule    String?
  room        String?
  batch       String?      // 👈 ADDED: Batch for the course (e.g., "2019-2023", "2020-2024")
  deletedAt   DateTime?
  deletedBy   Int?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  attendances Attendance[]
  teacher     Staff?       @relation(fields: [teacherId], references: [id])
  enrollments Enrollment[]
  lessons     Lesson[]
  materials   Material[]
  assignments Assignment[]

  @@index([department])
  @@index([teacherId])
  @@index([deletedAt])
  @@index([status])
  @@index([batch])
}

model Lesson {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  duration    String?  // e.g., "30 mins", "1 hour"
  content     String?  // Lesson content or video URL
  videoUrl    String?  // URL or path to video file
  pdfUrl      String?  // URL or path to PDF file
  order       Int      @default(0) // For ordering lessons
  courseId    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  materials   Material[]

  @@index([courseId])
  @@index([order])
}

model Material {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  fileName    String
  filePath    String   // Path to stored file
  fileSize    Int      // File size in bytes
  fileType    String   // MIME type (e.g., "application/pdf", "video/mp4")
  uploadedBy  Int      // Staff user ID who uploaded
  lessonId    Int
  courseId    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([lessonId])
  @@index([uploadedBy])
}

model Assignment {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  dueDate     DateTime?
  points      Int      @default(100)
  filePath    String?  // Optional assignment file
  courseId    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  submissions AssignmentSubmission[] // 👈 ADDED: Assignment submissions

  @@index([courseId])
  @@index([dueDate])
}

model AssignmentSubmission {
  id            Int      @id @default(autoincrement())
  assignmentId  Int
  studentId     Int
  filePath      String?  // Submitted file path
  submittedAt   DateTime @default(now())
  grade         Float?   // Grade out of 100
  feedback      String?  // Teacher feedback
  assignment    Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentId])
  @@index([assignmentId])
  @@index([studentId])
}

model Enrollment {
  id             Int      @id @default(autoincrement())
  studentId      Int
  courseId       Int
  enrollmentDate DateTime @default(now())
  status         String   @default("ACTIVE")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  course         Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student        Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId])
  @@index([studentId])
  @@index([courseId])
  @@index([status])
}

model Attendance {
  id        Int              @id @default(autoincrement())
  studentId Int
  courseId  Int
  date      DateTime
  status    AttendanceStatus @default(PRESENT)
  remarks   String?
  markedAt  DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  course    Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student   Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId, date])
  @@index([date])
  @@index([studentId])
  @@index([courseId])
  @@index([status])
}

enum Role {
  ADMIN
  STAFF
  STUDENT
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

model Trash {
  id            Int       @id @default(autoincrement())
  entity        String
  entityId      Int
  entityName    String?
  data          Json
  deletedBy     Int
  deletedAt     DateTime  @default(now())
  expiresAt     DateTime
  restoredAt    DateTime?
  restoredBy    Int?
  reason        String?
  ipAddress     String?
  createdAt     DateTime  @default(now())

  @@index([entity])
  @@index([entityId])
  @@index([deletedAt])
  @@index([expiresAt])
  @@index([deletedBy])
  @@index([restoredAt])
  @@index([entity, entityId])
}

model Log {
  id        Int       @id @default(autoincrement())
  userId    Int
  action    String
  entity    String
  entityId  Int
  oldData   Json?
  newData   Json?
  details   String?
  ipAddress String?
  userAgent String?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([entityId])
  @@index([createdAt])
}